---
pagination:
  data: collections.blogTags
  size: 1
  alias: tagdata
permalink: /blog/tags/{{ tagdata.tag | slug }}/
eleventyComputed:
  title: "blog posts tagged '{{ tagdata.tag }}'"
layout: page
---

<p class="text-gray-600 mb-6">{{ tagdata.count }} post{{ 's' if tagdata.count > 1 }}</p>

<div class="space-y-6">
{% for post in tagdata.posts %}
    <article class="border-b border-gray-200 pb-6">
        <h2 class="text-2xl font-semibold">
            <a href="{{ post.url }}" class="hover:underline">{{ post.data.title }}</a>
        </h2>
        <time class="text-sm text-gray-500">{{ post.date | readableDate }}</time>
        <div class="mt-2">
            {% for tag in post.data.tags %}
                <a href="/blog/tags/{{ tag | slug }}" 
                   class="text-sm bg-gray-100 px-2 py-1 rounded mr-2 hover:bg-gray-200">
                    {{ tag }}
                </a>
            {% endfor %}
        </div>
    </article>
{% endfor %}
</div>

<br>
<div class="mb-6">
        <a href="javascript:history.back()" class="text-gray-600 hover:text-gray-900 inline-flex items-center hover:underline">
            ⬅ back
        </a>
    </div>