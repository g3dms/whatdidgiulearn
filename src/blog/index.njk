---
layout: page
permalink: /blog/
title: Blog
---

<h1>Blog Posts</h1>

{% set posts = collections.blog %}

<p>Number of posts: {{ posts.length }}</p>

{% if posts.length > 0 %}
  <ul>
  {% for post in posts %}
    <li>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      <small>({{ post.date | readableDate }})</small>
    </li>
  {% endfor %}
  </ul>
{% else %}
  <p>No posts found.</p>
{% endif %}
