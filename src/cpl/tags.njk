---
pagination:
  data: collections.cplTags
  size: 1
  alias: tagdata
permalink: /cpl/tags/{{ tagdata.tag | slug }}/
eleventyComputed:
  title: "cpl posts tagged '{{ tagdata.tag }}'"
layout: page
---

<h1 class="text-3xl font-bold mb-2">cpl posts tagged "{{ tagdata.tag }}"</h1>
<p class="text-gray-600 mb-6">{{ tagdata.count }} post{{ 's' if tagdata.count > 1 }}</p>

<div class="space-y-6">
{% for post in tagdata.posts %}
    <article class="border-b border-gray-200 pb-6">
        <h2 class="text-2xl font-semibold">
            <a href="{{ post.url }}" class="hover:underline">{{ post.data.title }}</a>
        </h2>
        <time class="text-sm text-gray-500">{{ post.date | readableDate }}</time>
        <div class="mt-2">
            {% for tag in post.data.tags %}
                <a href="/cpl/tags/{{ tag | slug }}" 
                   class="text-sm bg-gray-100 px-2 py-1 rounded mr-2 hover:bg-gray-200">
                    {{ tag }}
                </a>
            {% endfor %}
        </div>
    </article>
{% endfor %}
</div>