---
title: Competitive Programming Log
layout: page.njk
---

{% for post in collections.blog | reverse %}
  <article>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <time>{{ post.data.date | readableDate }}</time>
    <p>{{ post.content | excerpt }}</p>
  </article>
{% endfor %}